RewriteEngine On

# Legal PDF documents must always be served as files, not routed through the SPA.
RewriteRule ^legal/.*\.pdf$ - [NC,L]

# Force known SPA routes to index.html even if stale route folders still exist on the server.
RewriteRule ^(start|rules|map|live|help|faq|account|admin|definitions|info|section|rule|leaderboard)(/.*)?$ index.html [L]

# Serve existing files and directories normally.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Clean URL fallback for the SPA routes.
RewriteRule ^ index.html [L]
